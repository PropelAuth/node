{
    "name": "@propelauth/cloudflare-worker",
    "repository": {
        "type": "git",
        "url": "https://github.com/PropelAuth/cloudflare-worker"
    },
    "version": "2.1.34",
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "keywords": [
        "auth",
        "cloudflare",
        "serverless"
    ],
    "devDependencies": {
        "@rollup/plugin-commonjs": "^19.0.2",
        "@rollup/plugin-node-resolve": "^13.3.0",
        "@rollup/plugin-typescript": "^8.5.0",
        "@types/express": "^4.17.25",
        "@types/jest": "^27.5.2",
        "@types/uuid": "^8.3.4",
        "jest": "^27.5.1",
        "nock": "^13.5.6",
        "prettier": "^2.8.8",
        "prettier-plugin-organize-imports": "^2.3.4",
        "rimraf": "^3.0.2",
        "rollup": "^2.80.0",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "ts-jest": "^27.1.5",
        "tslib": "^2.8.1",
        "typescript": "^4.9.5",
        "uuid": "^8.3.2"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "type-check:watch": "pnpm run type-check -- --watch",
        "build:types": "tsc --emitDeclarationOnly",
        "build:js": "rollup -c",
        "build": "pnpm run test && pnpm run build:types && pnpm run build:js",
        "test": "jest --silent",
        "prepublishOnly": "pnpm run build"
    },
    "module": "dist/index.mjs",
    "main": "dist/index.mjs",
    "typings": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "jest": {
        "testMatch": [
            "**/test/*.ts"
        ],
        "moduleFileExtensions": [
            "ts",
            "js"
        ],
        "transform": {
            "^.+\\.(ts|tsx)?$": "ts-jest"
        }
    },
    "dependencies": {
        "@propelauth/node-apis": "^2.1.35",
        "jose": "^5.10.0"
    }
}
